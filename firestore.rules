rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }

    // Fetch the user's account_type from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user is an admin or developer
    function isAdminOrDev() {
      return isLoggedIn() && 
        (getUserData().account_type == 'admin' || getUserData().account_type == 'developer');
    }

    match /users/{userId} {
      // Allow read/write if the user is the owner of the document
      allow read, write: if isLoggedIn() && request.auth.uid == userId;
      
      // Allow admin or developer to list all users, view their profiles, and change their account_type/verification_status
      allow read, write: if isAdminOrDev();
    }

    match /jobs/{jobId} {
      // Anyone (even unauthenticated) can read job listings
      allow read: if true;
      
      // Only admins or developers can create, update, or delete jobs
      allow write: if isAdminOrDev();
    }

    // Password-reset phone-verification lookup.
    // Doc ID = sha256(lowercased, trimmed email). Doc contains only hashes
    // (uid + phone hashes) — never plaintext phone numbers or profile data.
    match /passwordResetLookup/{emailHash} {
      // Anyone can fetch ONE doc by its exact known ID — this is all the
      // forgot-password flow needs, and it's the only thing this rule allows.
      allow get: if true;

      // Nobody can query/scan the collection — this is what keeps it safe
      // for unauthenticated access. Without this, the "get: true" rule above
      // would still block bulk queries by default, but being explicit here
      // makes the intent unambiguous.
      allow list: if false;

      // Only a logged-in user creating/updating THEIR OWN lookup doc
      // (uid inside the doc must match the caller's uid) is allowed to write.
      allow create: if isLoggedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid', 'phoneHash', 'secPhoneHash', 'whatsappHash']);

      allow update: if isLoggedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;

      // Only admins/devs can delete lookup docs (e.g. to fix a stale or
      // disputed entry).
      allow delete: if isAdminOrDev();
    }

    match /companies/{companyId} {
      // Anyone can read companies list for autocomplete dropdown
      allow read: if true;
      
      // Anyone can create a new company entry if non-empty, or logged in users can write
      allow create, update: if true;
    }
  }
}